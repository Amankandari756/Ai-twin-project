# AI Twin of Germany - Environment Variables
# Created by AMAN SINGH KANDARI

# Backend API URL (for frontend)
VITE_API_URL=http://localhost:8000

# Backend Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/ai_twin_germany
REDIS_URL=redis://localhost:6379/0

# API Keys (replace with actual keys for production)
DESTATIS_API_KEY=your_destatis_api_key_here
WEATHER_API_KEY=your_openweather_api_key_here

# ML Model Configuration
MODEL_UPDATE_INTERVAL=3600
PREDICTION_HORIZON_DAYS=30

# Debug Mode
DEBUG=true
LOG_LEVEL=info
